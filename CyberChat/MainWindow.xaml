<Window x:Class="CyberChat.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ CyberChatBot - Cybersecurity Chatbot" 
        Height="800" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="10" Margin="0,0,0,10" Padding="10">
            <StackPanel>
                <!-- CyberChatBot ASCII Art -->
                <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#4ECDC4" TextWrapping="NoWrap" HorizontalAlignment="Center" xml:space="preserve" Height="149" Width="713">
                    <TextBlock.Text>


                ██████╗██╗   ██╗██████╗ ███████╗██████╗     ██████╗██╗  ██╗ █████╗ ████████╗██████╗  ██████╗ ████████╗
               ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗   ██╔════╝██║  ██║██╔══██╗╚══██╔══╝██╔══██╗██╔═══██╗╚══██╔══╝
               ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝   ██║     ███████║███████║   ██║   ██████╔╝██║   ██║   ██║   
               ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗   ██║     ██╔══██║██╔══██║   ██║   ██╔══██╗██║   ██║   ██║   
               ╚██████╗   ██║   ██████╔╝███████╗██║  ██║   ╚██████╗██║  ██║██║  ██║   ██║   ██████╔╝╚██████╔╝   ██║   
                ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝    ╚═════╝╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝   ╚═════╝  ╚═════╝    ╚═╝





                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="🛡️ CYBERGUARDIAN" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0" Height="28"/>
                <TextBlock Text="Cybersecurity Awareness Assistant for South Africa" FontSize="12" Foreground="#BDC3C7" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Chat Display Area -->
        <ListBox x:Name="ChatDisplay" Grid.Row="2" Background="#ECF0F1" Margin="0,10" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 FontSize="14" BorderThickness="1" BorderBrush="#BDC3C7">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Area -->
        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="MessageInput" Grid.Column="0" Height="40" VerticalContentAlignment="Center"
                     FontSize="14" Background="White" 
                     BorderThickness="1" BorderBrush="#BDC3C7"
                     KeyDown="MessageInput_KeyDown"/>

            <Button x:Name="SendButton" Grid.Column="1" Width="80" Height="40" Margin="5,0,0,0"
                    Content="📤 Send" FontSize="14" FontWeight="Bold"
                    Background="#3498DB" Foreground="White"
                    Click="SendButton_Click"/>
        </Grid>

        <!-- Topic Buttons -->
        <WrapPanel Grid.Row="4" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button x:Name="BtnPassword" Content="🔐 Password Safety" Width="140" Height="35" Margin="5"
                    Background="#2ECC71" Foreground="White" FontWeight="Bold"
                    Click="TopicButton_Click"/>
            <Button x:Name="BtnPhishing" Content="🎣 Phishing" Width="120" Height="35" Margin="5"
                    Background="#E74C3C" Foreground="White" FontWeight="Bold"
                    Click="TopicButton_Click"/>
            <Button x:Name="BtnMalware" Content="🦠 Malware" Width="120" Height="35" Margin="5"
                    Background="#F39C12" Foreground="White" FontWeight="Bold"
                    Click="TopicButton_Click"/>
            <Button x:Name="Btn2FA" Content="🔑 2FA" Width="100" Height="35" Margin="5"
                    Background="#9B59B6" Foreground="White" FontWeight="Bold"
                    Click="TopicButton_Click"/>
            <Button x:Name="BtnWifi" Content="📶 Public WiFi" Width="130" Height="35" Margin="5"
                    Background="#1ABC9C" Foreground="White" FontWeight="Bold"
                    Click="TopicButton_Click"/>
            <Button x:Name="BtnHelp" Content="❓ Help" Width="100" Height="35" Margin="5"
                    Background="#34495E" Foreground="White" FontWeight="Bold"
                    Click="BtnHelp_Click"/>
            <Button x:Name="BtnExit" Content="❌ Exit" Width="100" Height="35" Margin="5"
                    Background="#95A5A6" Foreground="White" FontWeight="Bold"
                    Click="BtnExit_Click"/>
        </WrapPanel>
    </Grid>
</Window>
